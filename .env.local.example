MONGODB_URI=your_mongodb_atlas_connection_string
JWT_SECRET=replace_with_a_long_random_string

# Public app origin — used for magic-link URLs and CORS enforcement (BE-16)
APP_URL=https://your-domain.example

# Resend — sends real email over HTTPS (not SMTP), so it works reliably on
# serverless hosts like Vercel where SMTP ports are often blocked.
# Get a free API key at https://resend.com (3,000 emails/mo free).
# Omit in dev to fall back to console logging instead of sending.
RESEND_API_KEY=
# Must be a verified sender/domain in your Resend account.
RESEND_FROM=no-reply@your-domain.example

# BE-14: key for deterministic AES-256-GCM encryption of voter emails.
# Generate with: openssl rand -hex 32
FIELD_ENCRYPTION_KEY=

# BE-11: RSA keypair for signing the Valgprotokoll PDF. In production these
# should come from a real key vault (KMS/Vault), not a plain env var.
# Generate with: openssl genrsa 2048 | tee private.pem | openssl rsa -pubout -out public.pem
PROTOCOL_SIGNING_PRIVATE_KEY_PEM=
PROTOCOL_SIGNING_PUBLIC_KEY_PEM=

# BE-15: shared secret Vercel Cron sends as a Bearer token when invoking
# /api/cron/shred-pii. Set the same value as a Vercel env var named
# CRON_SECRET and Vercel will attach it automatically.
CRON_SECRET=
